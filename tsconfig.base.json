{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": false,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "preserve",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true,
    "paths": {
      "@den-web/components": ["libs/components/src/index.ts"],
      "@den-web/domain": ["libs/domain/src/index.ts"],
      "@den-web/feature-agents": ["libs/feature-agents/src/index.ts"],
      "@den-web/feature-conversation": ["libs/feature-conversation/src/index.ts"],
      "@den-web/feature-documents": ["libs/feature-documents/src/index.ts"],
      "@den-web/feature-librarian": ["libs/feature-librarian/src/index.ts"],
      "@den-web/feature-messages": ["libs/feature-messages/src/index.ts"],
      "@den-web/feature-notifications": ["libs/feature-notifications/src/index.ts"],
      "@den-web/feature-preferences": ["libs/feature-preferences/src/index.ts"],
      "@den-web/feature-projects": ["libs/feature-projects/src/index.ts"],
      "@den-web/feature-tasks": ["libs/feature-tasks/src/index.ts"],
      "@den-web/platform": ["libs/platform/src/index.ts"],
      "@den-web/protocol": ["libs/protocol/src/index.ts"],
      "@den-web/renderer": ["libs/renderer/src/index.ts"],
      "@den-web/shell": ["libs/shell/src/index.ts"],
      "@den-web/store": ["libs/store/src/index.ts"],
      "@den-web/testing-fixtures": ["libs/testing-fixtures/src/index.ts"],
      "@den-web/theme": ["libs/theme/src/index.ts"],
      "@den-web/transport": ["libs/transport/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist", "local"]
}
