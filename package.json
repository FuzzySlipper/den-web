{
  "name": "den-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nx serve den-web",
    "build": "nx run den-web:build",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "test": "vitest run --passWithNoTests",
    "test:static-server": "node tools/scripts/static-server-placeholder.mjs",
    "e2e": "nx e2e den-web-e2e",
    "verify": "npm run check:pattern && npm run check:docs && npm run check:connectivity && npm run lint && npm run typecheck && npm test && npm run build && npm run e2e",
    "check:all": "npm run verify",
    "check:pattern": "node tools/scripts/check-pattern.mjs",
    "check:docs": "node tools/scripts/check-docs-commands.mjs",
    "check:connectivity": "vitest run libs/transport/src/lib/connectivity-guard.test.ts",
    "serve:local": "node tools/scripts/serve-local.mjs",
    "deploy:den-srv": "node tools/scripts/deploy-placeholder.mjs"
  },
  "dependencies": {
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/router": "~21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@eslint/js": "^9.39.4",
    "@nx/angular": "23.0.1",
    "@nx/devkit": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.12.0",
    "@typescript-eslint/utils": "^8.61.1",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.4.0",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
