# Optional local development overrides for Den Web.
# Runtime deployments should prefer /den-web-config.json so the same static build
# can move between environments without rebuilding.

VITE_DEN_CORE_API_BASE=/den-core-api
VITE_DEN_CHANNELS_API_BASE=/api
VITE_DEN_HOST_API_BASE=/den-host-api
VITE_CONVERSATION_SUCCESSOR_READS_ENABLED=false
VITE_CONVERSATION_SUCCESSOR_WRITES_ENABLED=false
VITE_CONVERSATION_SUCCESSOR_API_BASE=/api/v1/conversation
VITE_CONVERSATION_SUCCESSOR_READ_PROJECT_IDS=
VITE_CONVERSATION_SUCCESSOR_WRITE_PROJECT_IDS=
VITE_TIMELINE_SUCCESSOR_ENABLED=false
VITE_TIMELINE_SUCCESSOR_API_BASE=/api/v1/timeline
VITE_TIMELINE_SUCCESSOR_PROJECT_IDS=
VITE_DEV_DEN_HOST_TARGET=http://localhost:5400
