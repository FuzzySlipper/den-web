# Optional local development overrides for Den Web.
# Runtime deployments should prefer /den-web-config.json so the same static build
# can move between environments without rebuilding.

VITE_DEN_CORE_API_BASE=/den-core-api
VITE_DEN_CHANNELS_API_BASE=/api
VITE_DEN_HOST_API_BASE=/den-host-api
VITE_DEV_DEN_HOST_TARGET=http://localhost:5400
